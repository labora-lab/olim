# Redis Configuration (used by Celery worker and docker-compose)
# For local deployment: use localhost or container name
# For remote workers: use actual Redis server IP/hostname
REDIS_HOST=localhost
# Redis server password (required for docker-compose redis service)
REDIS_PASSWORD=your-redis-password
# Redis server port (default: 6379)
REDIS_PORT=6379

# PostgreSQL Database Configuration
# For local deployment: container names are used automatically
# For remote workers: set DB_HOST to actual database server IP/hostname
POSTGRES_DB=olim
POSTGRES_USER=olim
POSTGRES_PASSWORD=your-db-password
POSTGRES_PORT=5432

# Remote Database Connection (for workers-only deployment)
# Set this to the actual database server hostname/IP when using workers-only setup
# Example: DB_HOST=192.168.1.100 or DB_HOST=db.example.com
DB_HOST=localhost

# Remote Elasticsearch (for workers-only deployment)
# Set this to the actual Elasticsearch server URL when using workers-only setup
# Example: ES_SERVER=http://192.168.1.100:9200
ES_SERVER=http://olim_es:9200

# Application Configuration
# Label types - available options:
# LabelTypes.YES_NO (default) - [("yes", "check", green), ("no", "clear", red)]
# LabelTypes.YES_NO_UNKNOWN - adds ("unknown", "?", orange)
# LabelTypes.YES_NO_IDK - adds ("don't know", "?", orange)
# LabelTypes.SIM_NAO - Portuguese [("sim", "check", green), ("não", "clear", red)]
# LabelTypes.SIM_NAO_NS - adds ("não sei", "?", orange)
# LabelTypes.CHECK - Single [("check", "check", green)]
LABELS=LabelTypes.YES_NO

# Optional help URL for the application (empty = no help link)
HELP_URL=

# Enable debug mode (default: false)
DEBUG=false